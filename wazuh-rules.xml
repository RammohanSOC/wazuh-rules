<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100111" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>
<group name="windows,sysmon,beaconing_final,">

  <!-- 1. THE TRAP: This rule MUST be at the top of local_rules.xml -->
  <rule id="100500" level="3">
    <if_sid>61600</if_sid>
    <!-- We match the specific IP and specific EventID 3 to ensure priority -->
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.destinationIp">^1\.1\.1\.1$</field>
    <description>DEBUG: Priority match for Test IP 1.1.1.1</description>
  </rule>

  <!-- 2. THE BEACON: 10 hits in 60s -->
  <rule id="100501" level="12" frequency="10" timeframe="60">
    <if_matched_sid>100500</if_matched_sid>
    <same_field>win.eventdata.image</same_field>
    <same_field>win.eventdata.destinationIp</same_field>
    <description>CRITICAL: Beaconing Pattern Detected to $(win.eventdata.destinationIp)</description>
    <mitre><id>T1071</id></mitre>
  </rule>

</group>
<!-- anomalous deletion detection -->

<group name="syscheck,sysmon,anomalous_deletion,">
  <rule id="100050" level="10">
    <if_sid>553</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)(cmd\.exe|powershell\.exe|wscript\.exe)</field>
    <description>Anomalous File Deletion: File deleted by a suspicious scripting process ($(win.eventdata.image)).</description>
    <mitre><id>T1070.004</id></mitre>
  </rule>

  <rule id="100051" level="12" frequency="50" timeframe="30">
    <if_matched_sid>553</if_matched_sid>
    <description>Anomalous File Deletion: Possible Ransomware activity detected (Mass file deletion).</description>
    <mitre><id>T1485</id></mitre>
  </rule>
</group>

<!-- privileged escalation detection -->
<group name="windows,psexec_detection,">
  <!-- Rule 100052: Detect PsExec service starting a process -->
  <rule id="100052" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)PSEXESVC\.exe</field>
    <description>PsExec Service spawned a child process ($(win.eventdata.image))</description>
    <mitre><id>T1569.002</id></mitre>
  </rule>

  <!-- Rule 100049: Detect if that child process is PowerShell (FIXED PARENT ID HERE) -->
  <rule id="100049" level="15">
    <if_sid>100052</if_sid> <!-- Changed from 160015 to 100052 -->
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <description>CRITICAL: Remote PowerShell execution via PsExec on $(win.system.computer)</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>
</group>

<!-- system crash dump access -->
<group name="sysmon_custom,windows,attack,">
  <rule id="100054" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)(procdump|mimikatz|nanodump|sqldumper)\.exe</field>
    <description>Wazuh - Attack - Known credential dumping tool executed: $(win.eventdata.image)</description>
    <mitre><id>T1003</id></mitre>
  </rule>

  <rule id="100055" level="14">
    <if_sid>61612</if_sid>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <field name="win.eventdata.sourceImage" type="pcre2" negate="yes">(?i)svchost\.exe|msmpeng\.exe|wininit\.exe|csrss\.exe|searchindexer\.exe</field>
    <description>Wazuh - Critical - Potential Credential Dump: $(win.eventdata.sourceImage) accessed LSASS memory</description>
    <mitre><id>T1003.001</id></mitre>
  </rule>

  <rule id="100056" level="10">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\.(dmp|mdmp)$</field>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)werfault\.exe</field>
    <description>Wazuh - Warning - Memory dump file (.dmp) created by $(win.eventdata.image)</description>
    <mitre><id>T1003</id></mitre>
  </rule>
</group>

<!-- suspicious command execution -->
<group name="suspicious_commands,">

  <!-- 1. The Root Rule: Matches any Sysmon Event -->
  <rule id="100080" level="0">
    <field name="win.system.providerName">^Microsoft-Windows-Sysmon$</field>
    <description>Sysmon event logs</description>
  </rule>

  <!-- 2. Match Process Creation (Event ID 1) -->
  <rule id="100081" level="0">
    <if_sid>100080</if_sid>
    <field name="win.system.eventID">^1$</field>
    <description>Sysmon - Event 1: Process creation</description>
  </rule>

  <!-- 3. Detect Encoded PowerShell -->
  <rule id="100082" level="12">
    <if_sid>100081</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-enc|EncodedCommand</field>
    <description>Suspicious Command: Encoded PowerShell detected</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <!-- 4. Detect Reconnaissance (whoami, net, ipconfig) -->
  <rule id="100083" level="7">
    <if_sid>100081</if_sid>
    <field name="win.eventdata.image" type="pcre2">whoami\.exe|net\.exe|ipconfig\.exe</field>
    <description>Suspicious Command: Reconnaissance tool $(win.eventdata.image)</description>
    <mitre><id>T1592</id></mitre>
  </rule>

</group>
<!--application installation -->
<group name="sysmon,windows,app_install">

  <!-- Rule 100001: Process Creation (Working for you) -->
  <rule id="100085" level="7">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image">msiexec.exe|setup.exe|install.exe</field>
    <description>Application Installer Process Started: $(win.eventdata.image)</description>
  </rule>

  <!-- Rule 100002: Registry Change (Simplified) -->
  <rule id="100086" level="5">
    <if_sid>61614, 61615</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">Uninstall</field>
    <description>Software Registry Entry Modified (Installation/Removal)</description>
  </rule>

  <!-- Rule 100003: File Creation (Simplified) -->
  <rule id="100087" level="5">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">Program Files</field>
    <description>File created in Program Files: $(win.eventdata.targetFilename)</description>
  </rule>

</group>
<!--suspecious powershell execution command-->
<group name="sysmon,powershell_malicious,">
  <!-- Detects PowerShell with suspicious flags -->
  <rule id="100088" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image">powershell.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-enc|-EncodedCommand|-NoP|-ExecutionPolicy Bypass|-WindowStyle Hidden</field>
    <description>Suspicious PowerShell command line execution detected: $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <!-- Detects PowerShell Download Cradles (IEX/DownloadString) -->
  <rule id="100089" level="13">
    <if_sid>100088</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Invoke-Expression|IEX|Net.WebClient|DownloadString|Invoke-WebRequest</field>
    <description>PowerShell Download Cradle detected: Potential malicious script download</description>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
  </group>i
