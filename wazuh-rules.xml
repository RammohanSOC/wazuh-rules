<group name="sysmon_network,">
  <!-- Rule for Sysmon Network Activity (Event ID 3) -->
  <rule id="100101" level="10">
    <if_sid>61605</if_sid>
    <description>Sysmon: Process $(win.eventdata.image) opened a network connection on port $(win.eventdata.destinationPort)</description>
  </rule>

  <!-- Rule for Inventory Changes (Port Opened/Closed) -->
  <rule id="100102" level="7">
    <if_sid>221</if_sid>
    <field name="type">dbsync_ports</field>
    <description>Inventory: Open port change detected on $(hostname)</description>
  </rule>
</group>
<!-- suspecious VPN connection -->
<group name="windows,sysmon,vpn_activity">

  <!-- 1. VPN Execution (Parented to your Rule 100081) -->
  <rule id="101001" level="10">
    <if_sid>100081</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)(openvpn|nordvpn|protonvpn|expressvpn|wireguard|hamachi|anyconnect|forticlient|tailscale)</field>
    <description>Suspicious VPN Client Execution: $(win.eventdata.image)</description>
  </rule>

  <!-- 2. VPN Network Connection (Parented to your Rule 100080) -->
  <rule id="101002" level="12">
    <if_sid>100080</if_sid>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(openvpn|wireguard|nordvpn|anyconnect|forticlient|tailscale)</field>
    <description>VPN Process initiated external network connection to $(win.eventdata.destinationIp)</description>
  </rule>

  <!-- 3. Driver Load (TAP/TUN) - Keeping this for completeness -->
  <rule id="101003" level="13">
    <if_sid>100080</if_sid>
    <field name="win.system.eventID">^6$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)(tap|tun|wireguard|wintun)</field>
    <description>VPN Tunnel Driver Loaded (TAP/TUN): $(win.eventdata.imageLoaded)</description>
  </rule>

</group>
<!--Active directory enumeration -->
<group name="windows,sysmon,recon,active_directory,">

  <!-- Suspicious PowerShell Flags -->
  <rule id="100600" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.Image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.CommandLine" type="pcre2">(?i)(-enc|-EncodedCommand|-nop|-w hidden)</field>
    <description>Suspicious PowerShell Execution Flags Detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell,suspicious_execution,</group>
  </rule>

  <!-- AD Enumeration Keywords -->
  <rule id="100601" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.CommandLine" type="pcre2">
      (?i)(Get-ADUser|Get-ADComputer|DirectorySearcher|LDAP://)
    </field>
    <description>Active Directory Enumeration Pattern Detected</description>
    <mitre>
      <id>T1087</id>
      <id>T1482</id>
    </mitre>
    <group>discovery,active_directory,</group>
  </rule>

  <!-- SharpHound Execution -->
  <rule id="100602" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.CommandLine" type="pcre2">(?i)(SharpHound|BloodHound)</field>
    <description>SharpHound / BloodHound Execution Detected</description>
    <mitre>
      <id>T1087</id>
    </mitre>
    <group>active_directory,recon,high_fidelity,</group>
  </rule>

  <!-- LDAP Network Connection -->
  <rule id="100603" level="9">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.DestinationPort">389|636|3268</field>
    <description>LDAP Connection Attempt Detected</description>
    <mitre>
      <id>T1482</id>
    </mitre>
    <group>network,ldap,recon,</group>
  </rule>


</group>
<!-- Unauthorized Network Share Access -->
<group name="windows,network_share_access">

  <!-- Combined Rule: Detects suspicious process + SMB port -->
  <rule id="100211" level="12">
    <if_sid>100080</if_sid>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.destinationPort">^445$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(powershell.exe|cmd.exe|psexec.exe|net.exe|certutil.exe)</field>
    <description>Suspicious Lateral Movement: $(win.eventdata.image) connected to SMB Share Port 445</description>
  </rule>

  <!-- Detect Administrative Share Name (Security Log 5140) -->
  <rule id="100212" level="14">
    <field name="win.system.eventID">^5140$</field>
    <field name="win.eventdata.shareName" type="pcre2">(?i)(ADMIN\$|C\$|IPC\$)</field>
    <description>CRITICAL: Administrative Share Accessed: $(win.eventdata.shareName)</description>
  </rule>

</group>
<!-- audit policy change -->
<group name="windows,policy_changes,">
  <rule id="110900" level="10">
    <field name="win.system.eventID">^4719$</field>
    <description>Audit Policy Changed: $(win.eventdata.subcategoryId)</description>
  </rule>
</group>
<!--port scanning-->
<group name="sysmon, port_scanning,">
  <!-- Base rule: Detect any Sysmon Event ID 3 -->
  <rule id="100001" level="0">
    <if_sid>61600</if_sid>
    <field name="win.system.eventID">^3$</field>
    <description>Sysmon - Event 3: Network connection</description>
  </rule>

  <!-- Port Scan Detection: Multiple connections to different ports in 60 seconds -->
  <rule id="100002" level="10" frequency="15" timeframe="60">
    <if_matched_sid>100001</if_matched_sid>
    <same_srcip />
    <different_dstport />
    <description>Potential Port Scan: High frequency of connections from $(win.eventdata.sourceIp) to multiple ports.</description>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>
</group>
<!--exessive file access by single user-->
<group name="file_access_test">

  <!-- Simple Base Rule -->
  <rule id="110801" level="3">
    <if_sid>60000</if_sid>
    <field name="win.system.eventID">^4663$</field>
    <match>Critical-folder</match>
    <description>DEBUG: Folder Access Detected</description>
  </rule>

  <!-- Simple Threshold Rule (Only 2 events needed to trigger) -->
  <rule id="110802" level="10" frequency="2" timeframe="60">
    <if_matched_sid>110801</if_matched_sid>
    <same_user />
    <description>DEBUG ALERT: Excessive Access Detected</description>
  </rule>

</group>
<!--powershell logging-->
<group name="windows,powershell">

  <rule id="100201" level="8">
    <if_sid>60009</if_sid>
    <field name="win.eventdata.payload" type="pcre2">(?i)CommandInvocation</field>
    <field name="win.system.message" type="pcre2">(?i)EncodedCommand|FromBase64String|EncodedArguments|-e\b|-enco\b|-en\b</field>
    <description>Encoded command executed via PowerShell.</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="100202" level="4">
    <if_sid>60009</if_sid>
    <field name="win.system.message" type="pcre2">(?i)blocked by your antivirus software</field>
    <description>Windows Security blocked malicious command executed via PowerShell.</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100203" level="10">
    <if_sid>60009</if_sid>
    <field name="win.eventdata.payload" type="pcre2">(?i)CommandInvocation</field>
    <field name="win.system.message" type="pcre2">(?i)Add-Persistence|Find-AVSignature|Get-GPPAutologon|Get-GPPPassword|Get-HttpStatus|Get-Keystrokes|Get-SecurityPackages|Get-TimedScreenshot|Get-VaultCredential|Get-VolumeShadowCopy|Install-SSP|Invoke-CredentialInjection|Invoke-DllInjection|Invoke-Mimikatz|Invoke-NinjaCopy|Invoke-Portscan|Invoke-ReflectivePEInjection|Invoke-ReverseDnsLookup|Invoke-Shellcode|Invoke-TokenManipulation|Invoke-WmiCommand|Mount-VolumeShadowCopy|New-ElevatedPersistenceOption|New-UserPersistenceOption|New-VolumeShadowCopy|Out-CompressedDll|Out-EncodedCommand|Out-EncryptedScript|Out-Minidump|PowerUp|PowerView|Remove-Comments|Remove-VolumeShadowCopy|Set-CriticalProcess|Set-MasterBootRecord</field>
    <description>Risky CMDLet executed. Possible malicious activity detected.</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100204" level="8">
    <if_sid>91802</if_sid>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)mshta.*GetObject|mshta.*new ActiveXObject</field>
    <description>Mshta used to download a file. Possible malicious activity detected.</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100205" level="5">
    <if_sid>60009</if_sid>
    <field name="win.eventdata.contextInfo" type="pcre2">(?i)ExecutionPolicy bypass|exec bypass</field>
    <description>PowerShell execution policy set to bypass.</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>
  <rule id="100206" level="5">
    <if_sid>60009</if_sid>
    <field name="win.system.message" type="pcre2">(?i)Invoke-WebRequest|IWR</field>
    <description>Invoke Webrequest executed, possible download cradle detected.</description>
  </rule>

</group>
<group name="sysmon_beacon_test,">

  <!-- Base match for Event ID 3 -->
  <rule id="100500" level="3">
    <field name="data.win.system.eventID">3</field>
    <field name="data.win.eventdata.initiated">true</field>
    <description>Base Sysmon Network Event</description>
  </rule>

  <rule id="100700" level="15" frequency="5" timeframe="60">
    <if_matched_sid>100500</if_matched_sid>
    <same_field>data.win.eventdata.destinationIp</same_field>
    <description>
    BEACON DETECTED: Multiple connections to $(data.win.eventdata.destinationIp)
    </description>
    <group>beaconing_test,</group>
  </rule>
</group>
