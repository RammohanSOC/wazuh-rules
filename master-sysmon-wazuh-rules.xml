<group name="custom_wazuh_rules">
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Suspicious File Download -->
<!-- ========================================================= -->
  <rule id="110001" level="10">
    <field name="win.system.eventID">11</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(\\Temp\\|\\Downloads\\)</field>
    <description>File created in Temp/Downloads</description>
    <group>sysmon,file_create,</group>
  </rule>
  <rule id="110002" level="12">
    <if_sid>110001</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\.(exe|ps1|bat|js|vbs|dll)$</field>
    <description>Suspicious file downloaded</description>
    <mitre><id>T1204.002</id></mitre>
  </rule>
    <!-- ========================================================= -->
    <!-- 🔹 USE CASE: Beaconing Detection -->
    <!-- ========================================================= -->
  <!--<rule id="110003" level="3">
    <if_group>sysmon_event3</if_group>
    <description>Sysmon network connection</description>
  </rule>
  <rule id="110004" level="12" frequency="15" timeframe="60">
    <if_matched_sid>110003</if_matched_sid>
    <same_field>win.eventdata.image</same_field>
    <same_field>win.eventdata.destinationIp</same_field>
    <description>Beaconing detected</description>
    <mitre><id>T1071</id></mitre>
  </rule> -->
  <rule id="110003" level="3">
    <if_group>sysmon_event3</if_group>

    <!-- Exclude Azure / system noise -->
    <field name="win.eventdata.image" negate="yes" type="pcre2">
    (?i)(WindowsAzureGuestAgent\.exe|svchost\.exe)
    </field>

    <description>Sysmon network connection (filtered)</description>
  </rule>
  <rule id="110004" level="12" frequency="15" timeframe="60">
    <if_matched_sid>110003</if_matched_sid>
    <same_field>win.eventdata.destinationIp</same_field>
    <same_field>win.eventdata.image</same_field>

    <description>Beaconing detected (filtered)</description>

    <mitre>
      <id>T1071</id>
    </mitre>
  </rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: unautherised File Deletion -->
<!-- ========================================================= -->
  <rule id="110005" level="5">
    <if_group>sysmon</if_group>
    <field name="win.system.eventID">23</field>
    <description>File deletion detected</description>
  </rule>
  <rule id="110006" level="12">
    <if_sid>110005</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)SensitiveData</field>
    <description>CRITICAL: Sensitive file deleted</description>
    <mitre><id>T1485</id></mitre>
  </rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Archive Extraction -->
<!-- ========================================================= -->
  <rule id="110007" level="16">
    <if_sid>92213</if_sid>
    <description>CRITICAL: Executable dropped (custom escalation)</description>
    <mitre>
      <id>T1560</id>
    </mitre>
  </rule>

<!-- ========================================================= -->
<!-- 🔹 USE CASE: Account Creation & Privilege Escalation -->
<!-- ========================================================= -->
<rule id="110008" level="10">
<if_group>windows_security</if_group>
<field name="win.system.eventID">4720</field>
<description>New user account created</description>
<mitre><id>T1136</id></mitre>
</rule>
<rule id="110009" level="12">
<if_group>windows_security</if_group>
<field name="win.system.eventID">4732</field>
<description>User added to Administrators group</description>
<mitre><id>T1098</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Credential Dumping -->
<!-- ========================================================= -->
<rule id="110010" level="12">
<if_group>sysmon_event1</if_group>
<field name="win.eventdata.image" type="pcre2">(?i)(mimikatz|procdump)</field>
<description>Credential dumping tool executed</description>
<mitre><id>T1003</id></mitre>
</rule>
<rule id="110011" level="14">
<if_group>sysmon_event10</if_group>
<field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
<description>LSASS access detected</description>
<mitre><id>T1003</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Suspicious PowerShell -->
<!-- ========================================================= -->
<rule id="110012" level="12">
<if_group>sysmon_event1</if_group>
<field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
<field name="win.eventdata.commandLine" type="pcre2">(?i)-enc|-ExecutionPolicy Bypass</field>
<description>Suspicious PowerShell execution</description>
<mitre><id>T1059.001</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Scheduled Task Persistence -->
<!-- ========================================================= -->
<rule id="110013" level="12">
<if_group>sysmon_event1</if_group>
<field name="win.eventdata.image" type="pcre2">(?i)schtasks\.exe</field>
<field name="win.eventdata.commandLine" type="pcre2">(?i)/create</field>
<description>Scheduled task created</description>
<mitre><id>T1053</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: RDP Brute Force -->
<!-- ========================================================= -->
<rule id="110014" level="10" frequency="5" timeframe="300">
<if_matched_sid>60122</if_matched_sid>
<same_field>win.eventdata.IpAddress</same_field>
<description>RDP brute force detected</description>
<mitre><id>T1110</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: Parent-Child Anomaly -->
<!-- ========================================================= -->
<rule id="110015" level="10">
<!-- Sysmon -->
<if_group>sysmon_event1</if_group>
<field name="win.eventdata.image" type="pcre2">(?i)cmd\\.exe</field>
<field name="win.eventdata.parentImage" type="pcre2">(?i)powershell\\.exe</field>

<description>Suspicious parent-child process (Sysmon)</description>
<mitre><id>T1059</id></mitre>
</rule>
<rule id="110016" level="10">
<!-- Windows Security -->
<if_sid>67027</if_sid>
<field name="win.eventdata.newProcessName" type="pcre2">(?i)cmd\\.exe</field>
<field name="win.eventdata.parentProcessName" type="pcre2">(?i)powershell\\.exe</field>

<description>Suspicious parent-child process (Security 4688)</description>
<mitre><id>T1059</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: FIM Ransomware Detection -->
<!-- ========================================================= -->
<rule id="110019" level="3">
<if_group>syscheck</if_group>
<description>FIM base event</description>
</rule>
<rule id="110017" level="12" frequency="20" timeframe="60">
<if_matched_sid>110019</if_matched_sid>
<description>Mass file modification detected</description>
<mitre><id>T1486</id></mitre>
</rule>
<!-- ========================================================= -->
<!-- 🔹 USE CASE: SMB Lateral Movement -->
<!-- ========================================================= -->
<rule id="110018" level="8">
<if_group>sysmon_event3</if_group>
<field name="win.eventdata.destinationPort">445</field>
<description>SMB connection detected</description>
<mitre><id>T1021</id></mitre>
</rule>
</group>
